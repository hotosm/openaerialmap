# Auto-detect nerdctl when docker is not installed (e.g. after `just prep machine`)
docker := env("DOCKER_ALIAS", if `command -v docker >/dev/null 2>&1 && echo found || echo missing` == "found" { "docker" } else { "nerdctl" })

# List available commands
[private]
default:
  just --justfile {{justfile()}} --list start

# Start OpenAerialMap (core services)
[no-cd]
all:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose up -d --build

# Start OpenAerialMap with global TMS tiles
[no-cd]
all-tms:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose --profile tms up -d --build

# Stop all services
[no-cd]
stop:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose --profile tms down

# Follow service logs (optionally specify a service name)
[no-cd]
logs *service:
  #!/usr/bin/env sh

  cd {{justfile_directory()}}
  {{docker}} compose logs -f {{service}}
