{
  "version": 8,
  "glyphs": "{fontstack}/{range}.pbf",
  "sources": {
    "global-coverage": {
      "type": "vector",
      "url": "pmtiles:///tiles/global-coverage.pmtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "rgba(0,0,0,0)" }
    },
    {
      "id": "density-fill",
      "source": "global-coverage",
      "source-layer": "density",
      "type": "fill",
      "minzoom": 0,
      "maxzoom": 10,
      "paint": {
        "fill-color": [
          "interpolate",
          ["linear"],
          ["get", "count"],
          1, "#cceeff",
          5, "#66b3ff",
          20, "#0066cc",
          50, "#003366"
        ],
        "fill-opacity": 0.7,
        "fill-outline-color": "rgba(255,255,255,0.6)"
      }
    },
    {
      "id": "density-count",
      "source": "global-coverage",
      "source-layer": "density",
      "type": "symbol",
      "minzoom": 2,
      "maxzoom": 10,
      "filter": [">", ["get", "count"], 0],
      "layout": {
        "text-field": ["to-string", ["get", "count"]],
        "text-font": ["Open Sans Bold"],
        "text-size": 12,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#0b2545",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "coverage-fill",
      "source": "global-coverage",
      "source-layer": "globalcoverage",
      "type": "fill",
      "minzoom": 10,
      "maxzoom": 14,
      "paint": {
        "fill-color": "#00E5FF",
        "fill-opacity": 0.15,
        "fill-outline-color": "#00B0FF"
      }
    }
  ]
}
