{
  "version": 8,
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "global-coverage": {
      "type": "vector",
      "tiles": [
        "pmtiles://http://127.0.0.1/global-coverage.pmtiles/{z}/{x}/{y}"
      ],
      "minzoom": 0,
      "maxzoom": 13
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "rgba(0,0,0,0)" }
    },
    {
      "id": "density-fill",
      "source": "global-coverage",
      "source-layer": "density",
      "type": "fill",
      "minzoom": 0,
      "maxzoom": 10,
      "paint": {
        "fill-color": [
          "interpolate",
          ["linear"],
          ["get", "count"],
          1,
          "#a8d8ff",
          10,
          "#66b3ff",
          50,
          "#0066cc",
          200,
          "#003366"
        ],
        "fill-opacity": 0.65,
        "fill-outline-color": "rgba(255,255,255,0.35)"
      }
    },
    {
      "id": "density-count",
      "source": "global-coverage",
      "source-layer": "density",
      "type": "symbol",
      "minzoom": 2,
      "maxzoom": 10,
      "filter": [
        "all",
        [">", ["get", "count"], 0],
        ["==", ["geometry-type"], "Point"]
      ],
      "layout": {
        "text-field": ["to-string", ["get", "count"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 15, 5, 18, 9, 22],
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#0b2545",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "coverage-fill",
      "source": "global-coverage",
      "source-layer": "globalcoverage",
      "type": "fill",
      "minzoom": 10,
      "maxzoom": 14,
      "paint": {
        "fill-color": "#00E5FF",
        "fill-opacity": 0.15,
        "fill-outline-color": "#00B0FF"
      }
    }
  ]
}
