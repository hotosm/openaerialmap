# Frontend
# PMTiles archive with per-image footprints (`globalcoverage` layer).
# Generated by backend/global-mosaic and uploaded to the oin-hotosm-temp
# bucket on the 12h cron. Rendered at zoom >= FOOTPRINT_MIN_ZOOM.
VITE_PMTILES_URL=${VITE_PMTILES_URL:-https://s3.amazonaws.com/oin-hotosm-temp/global-data.pmtiles}
# Density grid PMTiles - shared with backend/global-tms. Rendered
# below FOOTPRINT_MIN_ZOOM as an accurate "where is imagery" view.
VITE_DENSITY_PMTILES_URL=${VITE_DENSITY_PMTILES_URL:-https://s3.amazonaws.com/oin-hotosm-temp/global-coverage.pmtiles}
# TiTiler-PgSTAC endpoint on the eoapi stack. All per-image tile URLs
# and bounds lookups resolve through /collections/{c}/items/{id}/... .
VITE_STAC_TITILER_URL=${VITE_STAC_TITILER_URL:-https://api.imagery.hotosm.org/raster}
# STAC catalog root. Used to build STAC Browser deep-links from item ids.
VITE_STAC_URL=${VITE_STAC_URL:-https://api.imagery.hotosm.org/stac}
# STAC Browser root. Consumes VITE_STAC_URL item URLs via its
# #/external/ fragment and renders a full metadata page.
VITE_STAC_BROWSER_URL=${VITE_STAC_BROWSER_URL:-https://api.imagery.hotosm.org/browser}
# Tilepack packager service. Generates on-demand PMTiles / MBTiles
# archives for a single STAC item. Called from the Download PMTiles /
# MBTiles buttons in the browse UI. See backend/tilepack-api.
VITE_PACKAGER_URL=${VITE_PACKAGER_URL:-https://packager.imagery.hotosm.org}
# Optional: unlocks the Mapbox Satellite basemap in the toolbar. If unset
# the switcher hides that option.
VITE_MAPBOX_TOKEN=${VITE_MAPBOX_TOKEN:-}

# Local compose: Populate script
POPULATE_ITEMS=${POPULATE_ITEMS:-20}
